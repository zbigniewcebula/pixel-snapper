<Window x:Class="PixelSnapper.App.MainWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		Title="Pixel Snapper"
		Width="900" Height="600" MinWidth="720" MinHeight="480"
		Background="#1A1A1A"
		AllowDrop="True"
		PreviewDragOver="Window_PreviewDragOver"
		Drop="Window_Drop">
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="280"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<!-- Sidebar -->
		<Border Grid.Column="0" Background="#242424" BorderBrush="#333" BorderThickness="0,0,1,0" Padding="16">
			<StackPanel>
				<TextBlock Text="Pixel Snapper" FontSize="18" FontWeight="SemiBold" Foreground="#E8E8E8" Margin="0,0,0,12"/>
				<TextBlock Text="Parameters" FontSize="14" FontWeight="SemiBold" Foreground="#AAAAAA" Margin="0,0,0,8"/>

				<Grid Margin="0,0,0,12">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>

					<TextBlock Grid.Row="0" Grid.Column="0" Text="k_colors" Foreground="#BBBBBB" VerticalAlignment="Center" Margin="0,4"/>
					<TextBox x:Name="KColorsBox" Grid.Row="0" Grid.Column="1" Text="16" Margin="8,4,0,4"
							 Background="#1A1A1A" Foreground="#EEE" BorderBrush="#444" TextChanged="Params_Changed"/>

					<TextBlock Grid.Row="1" Grid.Column="0" Text="pixel_size" Foreground="#BBBBBB" VerticalAlignment="Top" Margin="0,4"/>
					<StackPanel Grid.Row="1" Grid.Column="1" Margin="8,4,0,4">
						<TextBox x:Name="PixelSizeBox" Background="#1A1A1A" Foreground="#EEE" BorderBrush="#444"
								 TextChanged="Params_Changed"/>
						<TextBlock Text="(empty = auto)" FontSize="10" Foreground="#777"/>
					</StackPanel>

					<TextBlock Grid.Row="2" Grid.Column="0" Text="pixel_size (detected)" Foreground="#BBBBBB" Margin="0,4"/>
					<TextBlock x:Name="DetectedSizeText" Grid.Row="2" Grid.Column="1" Text="—" Foreground="#CCC" Margin="8,4,0,4"/>

					<TextBlock Grid.Row="3" Grid.Column="0" Text="output size" Foreground="#BBBBBB" Margin="0,4"/>
					<TextBlock x:Name="OutputSizeText" Grid.Row="3" Grid.Column="1" Text="—" Foreground="#CCC" Margin="8,4,0,4"/>
				</Grid>

				<Button Content="Browse file…" Click="Browse_Click" Margin="0,0,0,8" Padding="8,6"
						Background="#333" Foreground="#EEE" BorderBrush="#555"/>
				<Button x:Name="SaveButton" Content="Save PNG" Click="Save_Click" IsEnabled="False" Padding="8,6"
						Background="#3D7EFF" Foreground="White" BorderThickness="0" Margin="0,0,0,12"/>
				<TextBlock x:Name="StatusText" Text="Drop a PNG/JPG image or browse for a file" TextWrapping="Wrap"
						   Foreground="#AAAAAA" FontSize="12"/>
			</StackPanel>
		</Border>

		<!-- Main -->
		<Grid Grid.Column="1" Margin="16">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<Border x:Name="DropZone" Grid.Row="0" Background="#2B2B2B" BorderBrush="#555" BorderThickness="2"
					CornerRadius="8" Padding="16" Margin="0,0,0,12" Cursor="Hand"
					AllowDrop="True" PreviewDragOver="DropZone_PreviewDragOver" Drop="DropZone_Drop"
					MouseLeftButtonUp="DropZone_Click">
				<StackPanel HorizontalAlignment="Center">
					<TextBlock Text="Drag and drop an image here" Foreground="#CCC" HorizontalAlignment="Center"/>
					<TextBlock Text="PNG, JPG, JPEG — or click to browse" Foreground="#999" FontSize="12"
							   HorizontalAlignment="Center" Margin="0,4,0,0"/>
				</StackPanel>
			</Border>

			<Grid Grid.Row="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

				<StackPanel Grid.Column="0" Margin="0,0,6,0">
					<TextBlock Text="Input" Foreground="#AAA" Margin="0,0,0,6"/>
					<Border Background="#2B2B2B" BorderBrush="#333" BorderThickness="1" CornerRadius="6" MinHeight="280">
						<Grid>
							<TextBlock x:Name="InputPlaceholder" Text="No image" Foreground="#666"
									   HorizontalAlignment="Center" VerticalAlignment="Center"/>
							<Image x:Name="InputPreview" Stretch="Uniform" Margin="8"
								   RenderOptions.BitmapScalingMode="NearestNeighbor" Visibility="Collapsed"/>
						</Grid>
					</Border>
				</StackPanel>

				<StackPanel Grid.Column="1" Margin="6,0,0,0">
					<TextBlock Text="Output" Foreground="#AAA" Margin="0,0,0,6"/>
					<Border x:Name="OutputFrame" Background="#2B2B2B" BorderBrush="#333" BorderThickness="1"
							CornerRadius="6" MinHeight="280">
						<Grid>
							<TextBlock x:Name="OutputPlaceholder" Text="No result" Foreground="#666"
									   HorizontalAlignment="Center" VerticalAlignment="Center"/>
							<Image x:Name="OutputPreview" Stretch="Uniform" Margin="8"
								   RenderOptions.BitmapScalingMode="NearestNeighbor" Visibility="Collapsed"/>
							<Border x:Name="LoadingOverlay" Background="#E02B2B2B" Visibility="Collapsed"
									CornerRadius="6">
								<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
									<ProgressBar IsIndeterminate="True" Width="120" Height="4" Margin="0,0,0,12"/>
									<TextBlock Text="Processing…" Foreground="#AAA" HorizontalAlignment="Center"/>
								</StackPanel>
							</Border>
						</Grid>
					</Border>
				</StackPanel>
			</Grid>
		</Grid>
	</Grid>
</Window>


